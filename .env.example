# Hermes Weather Trading Agent — Environment Configuration
# Copy to .env and fill in your API keys

# === REQUIRED ===

# LLM provider for strategy reasoning
STRATEGY_PROVIDER=openai_compatible
STRATEGY_BASE_URL=https://api.deepseek.com/v1
STRATEGY_MODEL=deepseek-chat
STRATEGY_API_KEY=sk-your-deepseek-api-key

# LLM provider for market classification
CLASSIFICATION_PROVIDER=openai_compatible
CLASSIFICATION_BASE_URL=https://api.deepseek.com/v1
CLASSIFICATION_MODEL=deepseek-chat
CLASSIFICATION_API_KEY=sk-your-deepseek-api-key

# === OPTIONAL (defaults shown) ===

# Polymarket Gamma API (public, no auth needed)
GAMMA_API_BASE_URL=https://gamma-api.polymarket.com

# Weather data source
WEATHER_API_BASE_URL=https://wttr.in

# Logging
LOG_LEVEL=INFO

# Data directory for SQLite databases (set by Docker, override for local)
# DATA_DIR=.

# Scheduler
# SCHEDULER_INTERVAL_MINUTES=30
# SCHEDULER_MODE=singapore

# Market quality thresholds
QUALITY_HIGH_THRESHOLD=0.02
QUALITY_LOW_THRESHOLD=0.06

# Risk management
AGENT_MAX_POSITION_USDC=50
AGENT_MAX_DAILY_LOSS_USDC=100
AGENT_MIN_CONFIDENCE=0.6
AGENT_MEDIUM_TIER_SIZE_MULTIPLIER=0.5

# Aggregation
AGENT_STRATEGY_N_REPEATS=5
AGENT_MIN_AGREEMENT_RATIO=0.7
AGENT_WEAK_AGREEMENT_THRESHOLD=0.8
AGENT_WEAK_AGREEMENT_MULTIPLIER=0.5
